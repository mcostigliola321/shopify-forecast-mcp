# shopify-forecast-mcp configuration
# Copy this file to `.env` and fill in the required values.

# --- Required ---
SHOPIFY_FORECAST_SHOP=mystore.myshopify.com
SHOPIFY_FORECAST_ACCESS_TOKEN=shpat_xxx

# --- Optional (defaults shown) ---
# SHOPIFY_FORECAST_API_VERSION=2026-04
# SHOPIFY_FORECAST_LOG_LEVEL=INFO

# --- TimesFM tuning ---
# SHOPIFY_FORECAST_TIMESFM_DEVICE=cpu           # cuda|cpu — no mps support on Apple Silicon (TimesFM 2.5 falls back to CPU)
# SHOPIFY_FORECAST_TIMESFM_CONTEXT_LENGTH=1024
# SHOPIFY_FORECAST_TIMESFM_HORIZON=90

# --- Caching ---
# SHOPIFY_FORECAST_FORECAST_CACHE_TTL=3600      # seconds
# SHOPIFY_FORECAST_HF_HOME=/opt/hf-cache        # HuggingFace cache dir override
